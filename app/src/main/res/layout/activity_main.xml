<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GPS Diagnostic for Xiaomi"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checks all factors that can cause location issues"
            android:textSize="14sp"
            android:textColor="#616161"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#E3F2FD">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Device Info"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />
                <TextView
                    android:id="@+id/tvDeviceInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Press Start Diagnostic for info"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:paddingTop="8dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#F3E5F5">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Live Satellite Tracking"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#6A1B9A" />
                <TextView
                    android:id="@+id/tvSatelliteInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Will show after diagnostic starts"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:paddingTop="8dp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnRunDiagnostic"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start GPS Diagnostic"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="12dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingBottom="12dp"
            android:gravity="center" />

        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: Run outdoors for best satellite results"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="32dp" />

    </LinearLayout>
</ScrollView>
